@@ -0,0 +1,319 @@
+"""
+Tests for pipeline/stage3_critic.py — tiered critic, claim builders,
+budget degradation, legacy status downgrade.
+
+Uses a stub LLM client (no real API calls) that returns canned verdicts
+keyed by the call label.
+"""
+
+from __future__ import annotations
+
+import json
+from dataclasses import dataclass, field
+
+import pytest
+
+from pipeline import stage3_critic
+from pipeline.config import OPUS_RETRY_BUDGET_PER_DOC
+from pipeline.schema import (
+    AlternativeItem,
+    ChunkRecord,
+    CriticValidation,
+    EISRecord,
+    EvidencePointer,
+    HistoricalContextClaim,
+    HistoricalContextInternal,
+    KeyPersonOrGroup,
+    LeadAgency,
+    LocationInfo,
+    OCRInfo,
+    QuoteItem,
+    SummaryField,
+    ThemesField,
+)
+
+
+@dataclass
+class _UsageStub:
+    total_input_tokens: int = 0
+    total_output_tokens: int = 0
+    total_cost_usd: float = 0.0
+    calls: int = 0
+
+
+class _StubLLMClient:
+    """
+    Drop-in replacement for pipeline.llm_client.LLMClient in tests.
+
+    `responses` maps a substring-of-label → response dict. Calls increment a
+    fixed cost so budget-degradation logic can be exercised deterministically.
+    """
+
+    def __init__(self, responses: dict[str, dict], cost_per_call: float = 0.01):
+        self.responses = responses
+        self.cost_per_call = cost_per_call
+        self.usage = _UsageStub()
+        self.call_log: list[tuple[str, str]] = []  # (model, label)
+
+    def call_json(self, model, system, messages, max_tokens=512, temperature=0.0, label=""):
+        self.call_log.append((model, label))
+        self.usage.calls += 1
+        self.usage.total_cost_usd += self.cost_per_call
+        for key, response in self.responses.items():
+            if key in label:
+                return response
+        # Default to "pass" if no rule matches — keeps unrelated fields quiet.
+        return {"verdict": "pass", "evidence_quote": None, "reasoning": "default stub pass"}
+
+
+def _make_record() -> EISRecord:
+    chunks = [
+        ChunkRecord(
+            chunk_id="c00",
+            title="Cover",
+            description="Cover and title page",
+            topic_tags=["other"],
+            pages=[1, 2, 3],
+            text=(
+                "FINAL ENVIRONMENTAL IMPACT STATEMENT\n"
+                "Cedar Creek Restoration Project\n"
+                "Prepared by the U.S. Forest Service\n"
+                "Published December 1998\n"
+            ),
+            used=True,
+        ),
+        ChunkRecord(
+            chunk_id="c01",
+            title="Purpose and Need",
+            description="Need for restoration",
+            topic_tags=["purpose_and_need", "affected_environment"],
+            pages=[4, 5, 6],
+            text=(
+                "Cedar Creek is located in Wyoming. The Forest Service has managed "
+                "the project area since 1948. A timber sale was initially proposed in 1974."
+            ),
+            used=True,
+        ),
+        ChunkRecord(
+            chunk_id="c02",
+            title="Alternatives",
+            description="Alternatives considered",
+            topic_tags=["alternatives"],
+            pages=[7, 8],
+            text=(
+                "Alternative A — No Action. Alternative B realigns the corridor "
+                "0.5 miles east to avoid the floodplain, adding three new interchanges."
+            ),
+            used=True,
+        ),
+    ]
+    return EISRecord(
+        doc_id="testdoc",
+        project_id="P9999",
+        title="Cedar Creek Restoration FEIS",
+        ocr=OCRInfo(median_confidence=0.9, page_count=8, unclear_document_flag=False),
+        eis_type="Final",
+        year=1998,
+        date="1998-12-01",
+        lead_agency=LeadAgency(name="U.S. Forest Service", source="mets"),
+        location=LocationInfo(name="Cedar Creek, Wyoming", state="WY"),
+        themes=ThemesField(primary=["land_management"], subthemes=["forestry"]),
+        summary=SummaryField(
+            text="The Forest Service proposes restoring Cedar Creek in Wyoming.",
+            evidence=[EvidencePointer(chunk_id="c01", pages=[4, 5])],
+            status="populated",
+        ),
+        alternatives_proposed=[
+            AlternativeItem(
+                name="No Action",
+                description="Do nothing.",
+                evidence=[EvidencePointer(chunk_id="c02", pages=[7])],
+            ),
+            AlternativeItem(
+                name="Alternative B",
+                description="Realigns the corridor 0.5 miles east, adding three interchanges.",
+                evidence=[EvidencePointer(chunk_id="c02", pages=[7])],
+            ),
+        ],
+        key_people_and_groups=[
+            KeyPersonOrGroup(
+                name="Sierra Club",
+                type="organization",
+                role="objecting party",
+                stance="opposed",
+                stance_evidence=[EvidencePointer(chunk_id="c01", pages=[4])],
+                quote=QuoteItem(
+                    text="The Forest Service has managed the project area since 1948.",
+                    chunk_id="c01",
+                    page=4,
+                    substring_verified=True,
+                ),
+            ),
+        ],
+        historical_context_internal=HistoricalContextInternal(
+            text="Project area has been managed since 1948.",
+            claims=[
+                HistoricalContextClaim(
+                    sentence="The Forest Service first proposed the timber sale in 1968.",
+                    evidence=[EvidencePointer(chunk_id="c01", pages=[4])],
+                ),
+            ],
+            status="populated",
+        ),
+        chunks=chunks,
+    )
+
+
+def test_claim_builder_title():
+    record = _make_record()
+    out = stage3_critic._build_claim_payloads(record, "title")
+    assert len(out) == 1
+    instance_path, claim, source = out[0]
+    assert instance_path == "title"
+    assert claim == "Cedar Creek Restoration FEIS"
+    assert "FINAL ENVIRONMENTAL IMPACT STATEMENT" in source
+
+
+def test_claim_builder_alternatives():
+    record = _make_record()
+    names = stage3_critic._build_claim_payloads(record, "alternatives_proposed[].name")
+    descs = stage3_critic._build_claim_payloads(
+        record, "alternatives_proposed[].description"
+    )
+    assert [p[0] for p in names] == [
+        "alternatives_proposed[0].name",
+        "alternatives_proposed[1].name",
+    ]
+    assert any("Alternative B" in p[1] for p in descs)
+
+
+def test_claim_builder_skips_when_no_value():
+    record = _make_record()
+    record.year = None
+    record.summary = None
+    assert stage3_critic._build_claim_payloads(record, "year") == []
+    assert stage3_critic._build_claim_payloads(record, "summary.text") == []
+
+
+def test_dispatch_marks_summary_no_and_downgrades_status():
+    """Summary verdict 'no' must downgrade summary.status to insufficient_information."""
+    record = _make_record()
+    client = _StubLLMClient(
+        responses={
+            "critic/sonnet/summary.text": {
+                "verdict": "no",
+                "evidence_quote": None,
+                "reasoning": "Summary mentions facts not in source.",
+            },
+            # Opus retry on summary also says no — so legacy downgrade kicks in.
+            "critic/opus/summary.text": {
+                "verdict": "no",
+                "evidence_quote": None,
+                "reasoning": "Confirmed: not in source.",
+            },
+        }
+    )
+    warnings = stage3_critic.run(record, client)
+    assert record.summary is not None
+    assert record.summary.status == "insufficient_information"
+    assert any(w.startswith("critic_failed: summary") for w in warnings)
+
+    # Verdict for summary.text is recorded on the record.
+    summary_verdicts = [
+        v for v in record.validation.verdicts if v.field_path == "summary.text"
+    ]
+    assert summary_verdicts and summary_verdicts[0].verdict == "no"
+    # Opus retry was triggered.
+    assert record.validation.opus_retries_used >= 1
+
+
+def test_dispatch_aggregates_pass_rate_and_review_status():
+    record = _make_record()
+    client = _StubLLMClient(
+        responses={}  # default stub returns "pass" for everything
+    )
+    stage3_critic.run(record, client)
+    assert record.validation.critic_pass_rate == 1.0
+    assert record.validation.review_status == "auto_approved"
+
+
+def test_dispatch_full_review_when_multiple_no():
+    record = _make_record()
+    client = _StubLLMClient(
+        responses={
+            "critic/sonnet/summary.text": {
+                "verdict": "no", "evidence_quote": None, "reasoning": "x",
+            },
+            "critic/opus/summary.text": {
+                "verdict": "no", "evidence_quote": None, "reasoning": "x",
+            },
+            "critic/sonnet/themes.primary": {
+                "verdict": "no", "evidence_quote": None, "reasoning": "y",
+            },
+            "critic/opus/themes.primary": {
+                "verdict": "no", "evidence_quote": None, "reasoning": "y",
+            },
+        }
+    )
+    stage3_critic.run(record, client)
+    assert record.validation.review_status == "full_review"
+
+
+def test_budget_pressure_skips_tiers():
+    """When cost is above the critic-budget cap, fields are marked skipped_budget_cap."""
+    record = _make_record()
+    # Use a stub that races past the cap on the first call.
+    client = _StubLLMClient(responses={}, cost_per_call=0.0)
+    client.usage.total_cost_usd = 10.0  # well above CRITIC_BUDGET_PER_DOC_USD = 3.0
+    stage3_critic.run(record, client)
+
+    # Every verdict should be skipped_budget_cap.
+    assert record.validation.verdicts, "Expected verdicts to be recorded even when skipped"
+    assert all(v.tier == "skipped_budget_cap" for v in record.validation.verdicts)
+    assert all(v.verdict == "skipped" for v in record.validation.verdicts)
+    assert record.validation.review_status == "not_run"
+
+
+def test_opus_retry_capped():
+    """Opus retries are capped at OPUS_RETRY_BUDGET_PER_DOC even with many sonnet 'no's."""
+    record = _make_record()
+    # Add many fake claims so sonnet "no" can fire repeatedly.
+    record.historical_context_internal.claims = [
+        HistoricalContextClaim(
+            sentence=f"Claim {i}",
+            evidence=[EvidencePointer(chunk_id="c01", pages=[4])],
+        )
+        for i in range(OPUS_RETRY_BUDGET_PER_DOC + 5)
+    ]
+    client = _StubLLMClient(
+        responses={
+            "critic/sonnet/historical_context_internal": {
+                "verdict": "no", "evidence_quote": None, "reasoning": "x",
+            },
+            "critic/opus/historical_context_internal": {
+                "verdict": "no", "evidence_quote": None, "reasoning": "x",
+            },
+        }
+    )
+    stage3_critic.run(record, client)
+    assert record.validation.opus_retries_used == OPUS_RETRY_BUDGET_PER_DOC
+
+
+def test_deterministic_layers_still_run_unchanged():
+    """Hard gates (quotes, year, themes, geocoding) still fire as before."""
+    record = _make_record()
+    # Inject a bad year and an invalid theme.
+    record.year = 1800  # < NEPA_YEAR
+    record.themes.primary = ["land_management", "not_a_theme"]
+    # Geocoding gap.
+    record.location.latitude = None
+    record.location.longitude = None
+
+    client = _StubLLMClient(responses={})
+    warnings = stage3_critic.run(record, client)
+
+    assert record.year is None  # year invalid → nulled
+    assert "not_a_theme" not in record.themes.primary
+    assert any("year_invalid" in w for w in warnings)
+    assert any("invalid_themes" in w for w in warnings)
+    assert any("geocoding_failed" in w for w in warnings)
