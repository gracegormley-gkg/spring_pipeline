+def _dispatch_critics(record: EISRecord, client: "LLMClient") -> CriticValidation:
+    """
+    Walk the CRITIC_TIERS table and emit one verdict per field_path
+    (or one per item for array-indexed fields). Apply Opus retry on Sonnet
+    "no" up to OPUS_RETRY_BUDGET_PER_DOC. Honor budget pressure: shed
+    Opus → Sonnet → Haiku.
+    """
+    verdicts: list[CriticVerdict] = []
+    opus_retries_used = 0
+
+    for field_path, tier in CRITIC_TIERS.items():
+        claims = _build_claim_payloads(record, field_path)
+        for instance_path, claim, source in claims:
+            allowed = _budget_state(client)
+            if not allowed.get(tier, False):
+                verdicts.append(CriticVerdict(
+                    field_path=instance_path,
+                    tier="skipped_budget_cap",
+                    verdict="skipped",
+                    evidence_quote=None,
+                    reasoning=f"budget_cap_skipped: tier={tier}",
+                ))
+                continue
+
+            v = _run_critic_call(tier, instance_path, claim, source, client)
+            # Sonnet "no" with budget headroom → Opus retry.
+            if (
+                tier == "sonnet"
+                and v.verdict == "no"
+                and opus_retries_used < OPUS_RETRY_BUDGET_PER_DOC
+                and _budget_state(client).get("opus", False)
+            ):
+                opus_retries_used += 1
+                retry_v = _run_critic_call("opus", instance_path, claim, source, client)
+                # Opus verdict is binding. Replace.
+                v = retry_v
+
+            verdicts.append(v)
+
+    # Aggregate
+    scored = [v for v in verdicts if v.verdict != "skipped"]
+    if scored:
+        pass_count = sum(1 for v in scored if v.verdict == "pass")
+        critic_pass_rate = pass_count / len(scored)
+    else:
+        critic_pass_rate = None
+
+    if critic_pass_rate is None:
+        review_status = "not_run"
+    else:
+        no_count = sum(1 for v in scored if v.verdict == "no")
+        if no_count >= 2:
+            review_status = "full_review"
+        elif no_count == 1:
+            review_status = "partial_review"
+        elif critic_pass_rate >= CRITIC_AUTO_APPROVE_PASS_RATE:
+            review_status = "auto_approved"
+        else:
+            # Mostly "partial" — needs eyes but not blocked.
+            review_status = "partial_review"
+
+    return CriticValidation(
+        verdicts=verdicts,
+        critic_pass_rate=critic_pass_rate,
+        review_status=review_status,  # type: ignore[arg-type]
+        opus_retries_used=opus_retries_used,
     )
 
 
