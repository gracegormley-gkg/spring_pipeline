+# ---------------------------------------------------------------------------
+# Stage 3 — Tiered critic
+# ---------------------------------------------------------------------------
+# Critic-stage soft budget: when the running per-doc total LLM cost exceeds
+# this number partway through Stage 3, tiers are shed in order
+# Opus → Sonnet → Haiku. The hard cap is still --budget-usd on run.py.
+CRITIC_BUDGET_PER_DOC_USD = 3.00
+
+# Cap on per-doc Opus retry calls (used only when Sonnet returns "no" on a
+# field whose correctness would otherwise block ship).
+OPUS_RETRY_BUDGET_PER_DOC = 3
+
+# Field path → critic tier. Field paths use the actual schema names from
+# pipeline/schema.py. Array-indexed fields use `[]` to indicate "per-item".
+# Tier maps to MODELS["light"] (haiku) or MODELS["critic"] (sonnet);
+# Opus retry uses MODELS["heavy"].
+CRITIC_TIERS: dict[str, str] = {
+    "title": "haiku",
+    "year": "haiku",
+    "eis_type": "haiku",
+    "lead_agency.name": "haiku",
+    "alternatives_proposed[].name": "haiku",
+    "summary.text": "sonnet",
+    "alternatives_proposed[].description": "sonnet",
+    "key_people_and_groups[].stance": "sonnet",
+    "themes.primary": "sonnet",
+    "location.name": "sonnet",
+    "historical_context_internal.claims[]": "sonnet",
+}
+
+# Auto-approve gate: fraction of critic-eligible fields that must return
+# "pass" for review_status = "auto_approved".
+CRITIC_AUTO_APPROVE_PASS_RATE = 0.90
