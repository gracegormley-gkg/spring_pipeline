+def _truncate(text: str, max_chars: int = 8000) -> str:
+    if len(text) <= max_chars:
+        return text
+    return text[:max_chars] + "\n[TRUNCATED]"
+
+
+def _cover_text(record: EISRecord, max_chars: int = 6000) -> str:
+    """First few chunks concatenated — approximates the document's title page area."""
+    parts: list[str] = []
+    total = 0
+    for c in record.chunks[:3]:
+        if total + len(c.text) > max_chars:
+            parts.append(c.text[: max_chars - total])
+            break
+        parts.append(c.text)
+        total += len(c.text)
+    return "\n".join(parts)
+
+
+def _chunk_text(record: EISRecord, chunk_id: str) -> str:
+    for c in record.chunks:
+        if c.chunk_id == chunk_id:
+            return c.text
+    return ""
+
+
