+def _run_critic_call(
+    tier: str,
+    field_path: str,
+    claim: str,
+    source: str,
+    client: "LLMClient",
+) -> CriticVerdict:
+    """Single critic LLM call. Returns a CriticVerdict."""
+    template = _load_prompt_template()
+    # Naive {placeholder} substitution; literal braces in the few-shots are
+    # JSON syntax that we never substitute into. The template uses unique
+    # placeholders only at the substitution sites.
+    filled = (
+        template
+        .replace("{tier}", tier, 2)  # appears in header and "Tier: {tier}" line
+        .replace("{field_path}", field_path, 2)
+        .replace("{claim}", claim)
+        .replace("{source}", source)
+        .replace("{output_schema}", _OUTPUT_SCHEMA_STR)
     )
+    # Split SYSTEM: ... from the rest as user content.
+    if filled.startswith("SYSTEM:\n"):
+        system_and_rest = filled[len("SYSTEM:\n"):]
+        # The few-shot + judging body is one user message; split on the judging marker.
+        marker = "NOW JUDGE THIS CLAIM:"
+        idx = system_and_rest.find(marker)
+        if idx >= 0:
+            system = system_and_rest[:idx].strip()
+            user = system_and_rest[idx:].strip()
+        else:
+            system = system_and_rest.strip()
+            user = f"Field path: {field_path}\nClaim:\n{claim}\n\nSource span:\n{source}"
+    else:
+        system = ""
+        user = filled
 
+    try:
+        result = client.call_json(
+            model=_model_for_tier(tier),
+            system=system,
+            messages=[{"role": "user", "content": user}],
+            max_tokens=512,
+            temperature=0.0,
+            label=f"critic/{tier}/{field_path}",
+        )
+    except Exception as exc:
+        logger.warning(
+            "Critic call failed for %s (%s): %s — recording as 'skipped'",
+            field_path, tier, exc,
+        )
+        return CriticVerdict(
+            field_path=field_path,
+            tier=tier,  # type: ignore[arg-type]
+            verdict="skipped",
+            evidence_quote=None,
+            reasoning=f"critic_call_error: {exc}",
+        )
 
