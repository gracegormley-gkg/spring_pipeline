+def append_critic_summary(
+    summary_path: str | Path,
+    doc_id: str,
+    validation: "CriticValidation",
+) -> None:
+    """
+    Append this run's critic validation summary to a sidecar JSON file.
+
+    Tracks per-field_path pass-rates across all runs so a Sonnet prompt
+    regression (e.g. summary going from 90% pass to 50%) is visible without
+    re-reading every output JSON.
+    """
+    path = Path(summary_path)
+    path.parent.mkdir(parents=True, exist_ok=True)
+
+    by_field: dict[str, dict[str, int]] = {}
+    for v in validation.verdicts:
+        # Collapse array-indexed instance paths back to their template key
+        # so verdicts on alternatives_proposed[0], [1], ... aggregate together.
+        key = _collapse_instance_path(v.field_path)
+        bucket = by_field.setdefault(key, {"pass": 0, "partial": 0, "no": 0, "skipped": 0})
+        bucket[v.verdict] = bucket.get(v.verdict, 0) + 1
+
+    entry = {
+        "timestamp": datetime.now(UTC).isoformat(),
+        "doc_id": doc_id,
+        "review_status": validation.review_status,
+        "critic_pass_rate": validation.critic_pass_rate,
+        "opus_retries_used": validation.opus_retries_used,
+        "critic_cost_usd": round(validation.critic_cost_usd, 6),
+        "by_field": by_field,
+    }
+
+    if path.exists():
+        try:
+            data = json.loads(path.read_text(encoding="utf-8"))
+            if not isinstance(data, dict) or "runs" not in data:
+                data = {"runs": []}
+        except (json.JSONDecodeError, OSError):
+            data = {"runs": []}
+    else:
+        data = {"runs": []}
+
+    data["runs"].append(entry)
+    data["aggregate"] = _aggregate_critic_runs(data["runs"])
+    path.write_text(json.dumps(data, indent=2), encoding="utf-8")
+
+
+def _collapse_instance_path(field_path: str) -> str:
+    """alternatives_proposed[3].name → alternatives_proposed[].name"""
+    import re
+    return re.sub(r"\[\d+\]", "[]", field_path)
+
+
+def _aggregate_critic_runs(runs: list[dict]) -> dict:
+    field_totals: dict[str, dict[str, int]] = {}
+    for r in runs:
+        for field, counts in (r.get("by_field") or {}).items():
+            agg = field_totals.setdefault(field, {"pass": 0, "partial": 0, "no": 0, "skipped": 0})
+            for k, v in counts.items():
+                agg[k] = agg.get(k, 0) + v
+
+    rates: dict[str, float | None] = {}
+    for field, counts in field_totals.items():
+        scored = counts.get("pass", 0) + counts.get("partial", 0) + counts.get("no", 0)
+        rates[field] = round(counts.get("pass", 0) / scored, 4) if scored else None
+
+    return {
+        "by_field_pass_rate": rates,
+        "by_field_counts": field_totals,
+        "total_runs": len(runs),
+    }
+
